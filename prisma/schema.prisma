generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum AppLocale {
  en
  zu
  xh
  af
  nso
  tn
}

enum UserRole {
  user
  admin
}

enum ContentStatus {
  draft
  published
}

enum PaymentDateState {
  expected
  pending
  portal_only
}

enum ReminderChannel {
  email
}

enum ReminderTrigger {
  one_day_before
  two_days_before
  on_publish
}

enum ReminderJobStatus {
  pending
  processing
  sent
  failed
  cancelled
}

enum ReminderAttemptStatus {
  sent
  failed
  skipped
}

enum MonetizationPlacement {
  payment_dates
  guide_inline
  dashboard_helpful
}

model User {
  id                    String                 @id @default(cuid())
  name                  String?
  email                 String                 @unique
  passwordHash          String?
  role                  UserRole               @default(user)
  preferredLocale       AppLocale              @default(en)
  preferredGrantTypeId  String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  preferredGrantType    GrantType?             @relation("PreferredGrantType", fields: [preferredGrantTypeId], references: [id], onDelete: SetNull)
  reminderSubscriptions ReminderSubscription[]
  reminderJobs          ReminderJob[]
  savedGuides           SavedGuide[]
  analyticsEvents       AnalyticsEvent[]
  passwordResetTokens   PasswordResetToken[]
}

model GrantType {
  id                    String                 @id @default(cuid())
  slug                  String                 @unique
  name                  String
  shortName             String?
  summary               String
  officialHref          String
  checks                Json?
  documents             Json?
  showInPaymentTool     Boolean                @default(false)
  showInGrantLibrary    Boolean                @default(true)
  paymentGroupId        String?
  sortOrder             Int                    @default(0)
  status                ContentStatus          @default(draft)
  publishedAt           DateTime?
  translations          Json?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  paymentGroup          GrantType?             @relation("GrantTypePaymentGroup", fields: [paymentGroupId], references: [id], onDelete: SetNull)
  paymentMembers        GrantType[]            @relation("GrantTypePaymentGroup")
  preferredByUsers      User[]                 @relation("PreferredGrantType")
  paymentDateEntries    PaymentDateEntry[]
  reminderSubscriptions ReminderSubscription[]
  reminderJobs          ReminderJob[]
  monetizationBlocks    MonetizationBlock[]

  @@index([status, sortOrder])
  @@index([showInPaymentTool, status, sortOrder])
  @@index([showInGrantLibrary, status, sortOrder])
}

model PaymentPeriod {
  id        String             @id @default(cuid())
  year      Int
  month     Int
  published Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  entries   PaymentDateEntry[]

  @@unique([year, month])
  @@index([published, year, month])
}

model PaymentDateEntry {
  id           String           @id @default(cuid())
  periodId     String
  grantTypeId  String
  state        PaymentDateState @default(pending)
  paymentDate  DateTime?
  note         String?
  published    Boolean          @default(false)
  publishedAt  DateTime?
  translations Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  period       PaymentPeriod    @relation(fields: [periodId], references: [id], onDelete: Cascade)
  grantType    GrantType        @relation(fields: [grantTypeId], references: [id], onDelete: Cascade)
  reminderJobs ReminderJob[]

  @@unique([periodId, grantTypeId])
  @@index([published, state])
}

model StatusMeaning {
  id           String        @id @default(cuid())
  slug         String        @unique
  title        String
  meaning      String
  causes       Json?
  fixes        Json?
  nextSteps    Json?
  officialHref String
  sortOrder    Int           @default(0)
  status       ContentStatus @default(draft)
  publishedAt  DateTime?
  translations Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status, sortOrder])
}

model GuideArticle {
  id                 String              @id @default(cuid())
  slug               String              @unique
  title              String
  summary            String
  sections           Json?
  featured           Boolean             @default(false)
  sponsored          Boolean             @default(false)
  sortOrder          Int                 @default(0)
  status             ContentStatus       @default(draft)
  publishedAt        DateTime?
  translations       Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  savedBy            SavedGuide[]
  monetizationBlocks MonetizationBlock[]

  @@index([status, sortOrder])
}

model NewsArticle {
  id           String        @id @default(cuid())
  slug         String        @unique
  title        String
  summary      String
  sections     Json?
  sourceUrls   Json?
  featured     Boolean       @default(false)
  sortOrder    Int           @default(0)
  status       ContentStatus @default(draft)
  publishedAt  DateTime?
  translations Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status, publishedAt, sortOrder])
}

model FaqEntry {
  id           String        @id @default(cuid())
  question     String
  answer       String
  sortOrder    Int           @default(0)
  status       ContentStatus @default(draft)
  publishedAt  DateTime?
  translations Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status, sortOrder])
}

model Notice {
  id           String        @id @default(cuid())
  slug         String        @unique
  title        String
  body         String
  href         String?
  tone         String        @default("notice")
  sortOrder    Int           @default(0)
  status       ContentStatus @default(draft)
  publishedAt  DateTime?
  startsAt     DateTime?
  endsAt       DateTime?
  translations Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status, sortOrder])
}

model SavedGuide {
  id        String       @id @default(cuid())
  userId    String
  guideId   String
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  guide     GuideArticle @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@unique([userId, guideId])
  @@index([userId, createdAt])
}

model ReminderSubscription {
  id             String          @id @default(cuid())
  userId         String
  grantTypeId    String
  channel        ReminderChannel @default(email)
  active         Boolean         @default(true)
  unsubscribedAt DateTime?
  oneDayBefore   Boolean         @default(false)
  twoDaysBefore  Boolean         @default(false)
  onPublish      Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantType      GrantType       @relation(fields: [grantTypeId], references: [id], onDelete: Cascade)
  reminderJobs   ReminderJob[]

  @@unique([userId, grantTypeId, channel])
  @@index([active, grantTypeId])
}

model ReminderJob {
  id                  String                @id @default(cuid())
  userId              String
  subscriptionId      String?
  grantTypeId         String
  paymentDateEntryId  String?
  channel             ReminderChannel       @default(email)
  trigger             ReminderTrigger
  status              ReminderJobStatus     @default(pending)
  scheduledFor        DateTime
  attemptCount        Int                   @default(0)
  processingStartedAt DateTime?
  lastAttemptAt       DateTime?
  sentAt              DateTime?
  lastError           String?
  cancelReason        String?
  providerMessageId   String?
  payload             Json?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription        ReminderSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  grantType           GrantType             @relation(fields: [grantTypeId], references: [id], onDelete: Cascade)
  paymentDateEntry    PaymentDateEntry?     @relation(fields: [paymentDateEntryId], references: [id], onDelete: SetNull)
  attempts            ReminderJobAttempt[]

  @@index([status, scheduledFor, attemptCount])
  @@index([paymentDateEntryId, trigger])
}

model ReminderJobAttempt {
  id                String                @id @default(cuid())
  jobId             String
  attemptNumber     Int
  status            ReminderAttemptStatus
  providerMessageId String?
  errorMessage      String?
  payload           Json?
  createdAt         DateTime              @default(now())
  job               ReminderJob           @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model AnalyticsEvent {
  id        String     @id @default(cuid())
  name      String
  locale    AppLocale?
  path      String?
  userId    String?
  payload   Json?
  createdAt DateTime   @default(now())
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([name, createdAt])
  @@index([path, createdAt])
  @@index([userId, createdAt])
}

model MonetizationBlock {
  id              String                @id @default(cuid())
  slug            String                @unique
  title           String
  body            String
  href            String
  ctaLabel        String?
  disclosureLabel String                @default("Sponsored")
  placement       MonetizationPlacement
  grantTypeId     String?
  guideId         String?
  sortOrder       Int                   @default(0)
  status          ContentStatus         @default(draft)
  publishedAt     DateTime?
  startsAt        DateTime?
  endsAt          DateTime?
  translations    Json?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  grantType       GrantType?            @relation(fields: [grantTypeId], references: [id], onDelete: SetNull)
  guide           GuideArticle?         @relation(fields: [guideId], references: [id], onDelete: SetNull)

  @@index([placement, status, sortOrder])
  @@index([grantTypeId, placement])
  @@index([guideId, placement])
}
