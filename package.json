{
  "name": "grantcare",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "db:setup:local": "npm run db:up && npm run db:push && npm run db:seed",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "content:publish:guide": "node --import tsx scripts/publish-guide.ts",
    "content:publish:news": "node --import tsx scripts/publish-news.ts",
    "content:sync:dates": "node --import tsx scripts/sync-payment-dates.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@prisma/client": "^6.19.3",
    "@react-email/components": "^1.0.11",
    "ai": "^6.0.167",
    "bcryptjs": "^3.0.3",
    "next": "16.2.3",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.10.0",
    "stripe": "^22.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "node --import tsx prisma/seed.ts"
  }
}
